generator client {
  provider = "prisma-client"
  output   = "../generated/prisma"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id           String  @id @default(cuid())
  email        String  @unique
  fullName     String
  passwordHash String?
  provider     String  @default("local")
  googleId     String? @unique

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  refreshTokens     RefreshToken[]
  nutritionSettings UserNutritionSettings?
  pantryProducts    PantryProduct[]
  pantryRecipes     PantryRecipe[]
  savedMeals        SavedMeal[]
  dayLogs           DayLog[]

  createdCatalogItems ProductCatalogItem[] @relation("ProductCatalogCreatedBy")
  updatedCatalogItems ProductCatalogItem[] @relation("ProductCatalogUpdatedBy")

  @@index([email])
}

model UserNutritionSettings {
  id                  String  @id @default(cuid())
  userId              String  @unique
  experienceMode      String  @default("GUIDED")
  targetMode          String  @default("AUTO")
  onboardingCompleted Boolean @default(false)
  preferredLanguage   String  @default("he")
  dailyCaloriesTarget Int?
  proteinTarget       Int?
  carbsTarget         Int?
  fatTarget           Int?
  fiberTarget         Int?

  // Profile
  gender              String?
  birthDate           DateTime?
  heightCm            Float?
  weightKg            Float?
  trainingDaysPerWeek Int?
  goalType            String?

  // Display
  themeMode String @default("LIGHT")

  // Tracking preferences
  showFiberOnHome            Boolean @default(true)
  showCarbsAndFatOnHome      Boolean @default(true)
  showProgressPercentages    Boolean @default(true)
  showWeeklyBalance          Boolean @default(true)
  showGuidedSuggestions      Boolean @default(true)
  hideMotivationInExpertMode Boolean @default(true)
  defaultFoodUnit            String  @default("GRAMS")

  // Notification preferences
  breakfastReminderEnabled Boolean @default(false)
  breakfastReminderTime    String?
  lunchReminderEnabled     Boolean @default(false)
  lunchReminderTime        String?
  dinnerReminderEnabled    Boolean @default(false)
  dinnerReminderTime       String?
  waterReminderEnabled     Boolean @default(false)
  waterReminderInterval    Int?
  dailySummaryEnabled      Boolean @default(false)
  dailySummaryTime         String?
  weeklySummaryEnabled     Boolean @default(false)
  weeklySummaryDay         Int?
  weeklySummaryTime        String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model ProductCatalogItem {
  id String @id @default(cuid())

  barcode           String? @unique
  gtin              String?
  normalizedBarcode String?

  name         String
  brand        String?
  manufacturer String?
  category     String?
  subCategory  String?

  countryCode  String? @default("IL")
  languageCode String? @default("he")

  imageUrl        String?
  ingredientsText String?
  allergensText   String?

  servingSizeText  String?
  servingSizeGrams Float?

  caloriesPer100g     Float?
  proteinPer100g      Float?
  carbsPer100g        Float?
  sugarPer100g        Float?
  fatPer100g          Float?
  saturatedFatPer100g Float?
  fiberPer100g        Float?
  sodiumPer100g       Float?
  saltPer100g         Float?

  source             ProductSource             @default(MANUAL)
  verificationStatus ProductVerificationStatus @default(UNVERIFIED)

  externalProvider String?
  externalId       String?
  externalRawData  Json?

  createdByUserId String?
  updatedByUserId String?

  createdByUser User? @relation("ProductCatalogCreatedBy", fields: [createdByUserId], references: [id], onDelete: SetNull)
  updatedByUser User? @relation("ProductCatalogUpdatedBy", fields: [updatedByUserId], references: [id], onDelete: SetNull)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([barcode])
  @@index([normalizedBarcode])
  @@index([name])
  @@index([brand])
  @@index([category])
  @@index([countryCode])
  @@index([source])
  @@index([verificationStatus])
  @@index([createdByUserId])
}

enum ProductSource {
  INTERNAL
  OPEN_FOOD_FACTS
  MANUAL
  ADMIN
}

enum ProductVerificationStatus {
  UNVERIFIED
  USER_SUBMITTED
  AUTO_IMPORTED
  ADMIN_VERIFIED
  REJECTED
}

model RefreshToken {
  id        String   @id @default(cuid())
  tokenHash String   @unique
  userId    String
  expiresAt DateTime
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([tokenHash])
}

model PantryProduct {
  id              String  @id @default(cuid())
  userId          String
  name            String
  brand           String?
  barcode         String?
  caloriesPer100g Float
  proteinPer100g  Float
  carbsPer100g    Float
  fatPer100g      Float
  fiberPer100g    Float?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user            User               @relation(fields: [userId], references: [id], onDelete: Cascade)
  recipeItems     PantryRecipeItem[]
  savedMealItems SavedMealItem[]
  mealItems      MealItem[]

  @@unique([userId, barcode])
  @@index([userId])
  @@index([barcode])
}

model PantryRecipe {
  id          String  @id @default(cuid())
  userId      String
  name        String
  description String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user           User               @relation(fields: [userId], references: [id], onDelete: Cascade)
  items          PantryRecipeItem[]
  savedMealItems SavedMealItem[]
  mealItems      MealItem[]

  @@index([userId])
}

model PantryRecipeItem {
  id        String @id @default(cuid())
  recipeId  String
  productId String
  grams     Float

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  recipe  PantryRecipe  @relation(fields: [recipeId], references: [id], onDelete: Cascade)
  product PantryProduct @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@index([recipeId])
}

model SavedMeal {
  id       String  @id @default(cuid())
  userId   String
  name     String
  mealType String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user      User            @relation(fields: [userId], references: [id], onDelete: Cascade)
  items     SavedMealItem[]
  mealItems MealItem[]

  @@index([userId])
}

model SavedMealItem {
  id          String  @id @default(cuid())
  savedMealId String
  productId   String?
  recipeId    String?
  grams       Float?
  servings    Float?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  savedMeal SavedMeal      @relation(fields: [savedMealId], references: [id], onDelete: Cascade)
  product   PantryProduct? @relation(fields: [productId], references: [id], onDelete: SetNull)
  recipe    PantryRecipe?  @relation(fields: [recipeId], references: [id], onDelete: SetNull)

  @@index([savedMealId])
}
model DayLog {
  id              String  @id @default(cuid())
  userId          String
  date            String
  targetsSnapshot Json
  caloriesTotal   Float   @default(0)
  proteinTotal    Float   @default(0)
  carbsTotal      Float   @default(0)
  fatTotal        Float   @default(0)
  fiberTotal      Float   @default(0)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user        User        @relation(fields: [userId], references: [id], onDelete: Cascade)
  mealEntries MealEntry[]

  @@unique([userId, date])
  @@index([userId])
}

model MealEntry {
  id       String @id @default(cuid())
  dayLogId String
  mealType String

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  dayLog DayLog     @relation(fields: [dayLogId], references: [id], onDelete: Cascade)
  items  MealItem[]

  @@unique([dayLogId, mealType])
  @@index([dayLogId])
}

model MealItem {
  id              String  @id @default(cuid())
  mealEntryId     String
  pantryProductId String?
  pantryRecipeId  String?
  savedMealId     String?
  grams           Float?
  servings        Float?
  macrosSnapshot  Json

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  mealEntry     MealEntry      @relation(fields: [mealEntryId], references: [id], onDelete: Cascade)
  pantryProduct PantryProduct? @relation(fields: [pantryProductId], references: [id], onDelete: SetNull)
  pantryRecipe  PantryRecipe?  @relation(fields: [pantryRecipeId], references: [id], onDelete: SetNull)
  savedMeal     SavedMeal?     @relation(fields: [savedMealId], references: [id], onDelete: SetNull)

  @@index([mealEntryId])
}
